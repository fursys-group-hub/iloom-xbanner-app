    "_의사_코드": "function classifyCase(data) { if (!data.박람회 || data.박람회.참여여부 === false) return 'F'; if (data.기본정보_2아파트 && data.기본정보_2아파트.length === 2) return 'D'; if (data.박람회_2개) return 'D'; if (data.박람회.기간_차수 && data.박람회.기간_차수.length >= 2) return 'E'; if (data.특별프로모션 && data.특별프로모션.length >= 3) return 'B'; const PRODUCT_KW = ['옷장단독', '모션', '소파', '학생방']; const product_count = (data.특별프로모션 || []).filter(p => PRODUCT_KW.includes(p)).length; if (product_count >= 1) return 'C'; return 'A'; }",

