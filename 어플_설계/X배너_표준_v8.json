    "_의사_코드": "function reorderSection(layout, section_id, new_index) { if (FIXED_SECTIONS.includes(section_id)) throw new Error('헤더와 하단은 이동 불가'); const sections = layout.sections.filter(s => !FIXED_SECTIONS.includes(s.id)); const moved = sections.splice(sections.findIndex(s => s.id === section_id), 1)[0]; sections.splice(new_index, 0, moved); const new_layout = { ...layout, sections: [layout.sections.find(s => s.id === 'header'), ...sections, layout.sections.find(s => s.id === 'footer')] }; return applyBlankSpaceAlgorithm(new_layout); }"
