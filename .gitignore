# 의존성 패키지 (npm install 로 다시 받음 — 올릴 필요 없음)
node_modules/
app/node_modules/

# 환경변수(비밀 키) — 절대 올리지 말 것
.env
app/.env
*.env.local

# 배경 사진 원본 백업 (용량 큼 — 로컬에만 보관, 배포 안 함)
assets/_배경_원본_백업/

# 임시 파일
_tmp-payload.json
*.tmp
*.log

# 스크린샷/검증 출력물 (자동 생성됨)
app/scripts/output/

# 화면 녹화 영상 (용량이 커서 GitHub 제한 초과 — 제외)
*.mp4
*.mov

# OS 자동 생성 파일
Thumbs.db
.DS_Store
desktop.ini

# 에디터 설정
.vscode/
.idea/
