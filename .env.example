# 일룸 X배너 어플 — 환경변수 예시 (키 이름만, 실제 값은 넣지 말 것)
# 실제 값은 .env 에 채우세요. .env 는 .gitignore 로 제외되어 올라가지 않습니다.

# 사내 제품 가이드(iloomproduct.fursys.com) 이미지 수집 스크립트용 로그인 정보
# ⚠️ 코드에 하드코딩돼 GitHub에 노출됐던 비밀번호는 폐기·재발급(변경) 후 새 값을 넣으세요.
ILOOM_LOGIN_ID=
ILOOM_LOGIN_PW=
# (선택) 로그인 URL — 기본값: https://iloomproduct.fursys.com/wp-login.php
ILOOM_LOGIN_URL=

# 앱 서버
PORT=
# 로그인 토큰 위조 방지용 비밀키 (배포 시 안전한 무작위 값으로 자동 생성)
SESSION_SECRET=
# Supabase(외부 저장소) — 로그인·저장 기능 사용 시 필요
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
